NEXT_PUBLIC_APP_NAME="Canvas Accessibility Converter"
APP_BASE_URL="http://localhost:3000"

DATABASE_PATH=".data/capstone.db"
STORAGE_ROOT=".storage"
MAX_UPLOAD_BYTES="10485760"
RETENTION_DAYS="30"

OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_TIMEOUT_SECONDS="45"
OPENAI_MAX_RETRIES="3"

SESSION_COOKIE_NAME="cac_session"
SESSION_TTL_HOURS="12"
SESSION_SECURE="false"

SAML_SP_ENTITY_ID="urn:canvas-accessibility-converter:sp"
SAML_SP_ACS_URL="http://localhost:3000/api/auth/saml/callback"
SAML_IDP_ENTITY_ID=""
SAML_IDP_SSO_URL=""
SAML_IDP_CERT=""
SAML_ATTRIBUTE_UID="uid"
SAML_ATTRIBUTE_EMAIL="email"
SAML_ATTRIBUTE_NAME="displayName"

ADMIN_EMAILS="admin1@osu.edu,admin2@osu.edu"
WORKER_POLL_MS="5000"
